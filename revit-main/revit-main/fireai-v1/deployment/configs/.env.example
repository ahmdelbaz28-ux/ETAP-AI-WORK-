# FireAI v1.0 Environment Configuration

# Application Settings
NODE_ENV=production
PORT=8000

# Security
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Database
MONGODB_URI=mongodb://localhost:27017/fireai
REDIS_URL=redis://localhost:6379

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# API Limits
MAX_REQUEST_SIZE=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# FACP Configuration
FACP_PROTOCOL_VERSION=FACP/1.1
FACP_DEFAULT_TIMEOUT=8000
FACP_MAX_TIMEOUT=30000
FACP_MAX_MEMORY_MB=1024
FACP_MAX_RECURSION_DEPTH=10

# Agent Configuration
AGENT_MAX_CONCURRENT_TASKS=10
AGENT_TIMEOUT_MS=30000

# Execution Engine
EXECUTION_MAX_CONCURRENT=10
EXECUTION_DEFAULT_TIMEOUT=8000
EXECUTION_MAX_TIMEOUT=30000

# Security Headers
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_CONTENT_TYPE_OPTIONS=nosniff
SECURE_FRAMEGUARD=denny

# SSL/TLS (if applicable)
SSL_CERT_PATH=/path/to/certificate.pem
SSL_KEY_PATH=/path/to/private-key.pem