{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    /* Linting — SECURITY/QUALITY: strict mode enabled in v2.1.1.
       Was previously disabled (noUnusedLocals: false, noUnusedParameters: false,
       no strict: true) which masked type errors and unused variables.
       The flags below are now ON. Existing code that violates them will be
       flagged by `tsc --noEmit`; fix incrementally by either:
         1. Removing unused imports/vars (preferred)
         2. Prefixing intentionally-unused args with underscore (e.g. _event)
         3. Adding `// eslint-disable-next-line @typescript-eslint/no-explicit-any`
            where `any` is genuinely needed (e.g. third-party JSON payloads) */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "forceConsistentCasingInFileNames": true,
    "allowUnreachableCode": false
  },
  "include": ["src"]
}
