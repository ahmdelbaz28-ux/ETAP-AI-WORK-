{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build:all": "vite build && electron-builder --win --linux --mac"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.etap.ai-platform",
    "productName": "Ahmed etap Platform",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "msi": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/favicon.svg"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "lucide-react": "1.18.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.8",
    "react-icons": "5.6.0",
    "react-router-dom": "7.17.0",
    "recharts": "3.8.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.3.3",
    "electron-builder": "26.15.2",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.12",
    "vitest": "4.1.8",
    "wait-on": "9.0.10"
  }
}
