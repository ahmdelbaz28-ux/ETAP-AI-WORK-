{
  "name": "ui",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:vercel": "vite build",
    "build:index": "python ../../indexer.py && cp ../help/search-index.json ./src/components/command/search-index-data.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build:all": "vite build && electron-builder --win --linux --mac"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.etap.ai-platform",
    "productName": "Ahmed etap Platform",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "msi": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/favicon.svg"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.7",
    "@tanstack/react-query": "^5.101.1",
    "clsx": "2.1.1",
    "framer-motion": "11.18.0",
    "i18next": "24.2.2",
    "i18next-browser-languagedetector": "8.0.4",
    "lucide-react": "0.468.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "15.4.1",
    "react-icons": "5.4.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.1.1",
    "recharts": "2.15.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "2.6.0",
    "tailwindcss": "4.0.0",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.1.0",
    "cross-env": "10.1.0",
    "electron": "33.2.1",
    "electron-builder": "25.1.8",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.14.0",
    "jsdom": "25.0.1",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vite": "6.4.3",
    "vitest": "3.0.9",
    "wait-on": "8.0.3"
  }
}
