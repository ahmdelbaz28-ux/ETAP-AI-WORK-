{
  "name": "ui",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:vercel": "vite build",
    "build:index": "python ../../indexer.py && cp ../help/search-index.json ./src/components/command/search-index-data.json",
    "lint": "npm exec biome check .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build:all": "vite build && electron-builder --win --linux --mac"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.etap.ai-platform",
    "productName": "Ahmed etap Platform",
    "files": ["dist/**/*", "electron/**/*"],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "msi"],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "msi": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/favicon.svg"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query": "^5.101.1",
    "clsx": "2.1.1",
    "framer-motion": "11.18.0",
    "i18next": "24.2.2",
    "i18next-browser-languagedetector": "8.2.1",
    "lucide-react": "^0.468.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "15.4.1",
    "react-icons": "5.7.0",
    "react-is": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.18.1",
    "recharts": "3.9.2",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.25.0",
    "tailwind-merge": "2.6.0",
    "tailwindcss": "4.3.2",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/js": "9.17.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "10.0.3",
    "cross-env": "7.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "15.14.0",
    "jsdom": "29.1.1",
    "typescript": "5.7.2",
    "typescript-eslint": "8.63.0",
    "vite": "6.4.3",
    "vitest": "3.2.6",
    "wait-on": "9.0.10"
  }
}
