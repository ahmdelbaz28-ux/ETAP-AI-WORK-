#!/bin/sh
#
# Pre-commit hook — prevent accidental commits of .env
#
# This hook checks whether the .env file (which contains live secrets)
# is staged for commit and aborts with a clear error message.
#
# Install:
#   git config core.hooksPath .githooks
#
# To bypass (only when you really mean it):
#   git commit --no-verify

FILES_STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if echo "$FILES_STAGED" | grep -qxE '\.env$'; then
  echo ""
  echo "  ❌  ABORTING COMMIT — .env file is staged!"
  echo ""
  echo "  The .env file contains live secrets (API keys, database passwords,"
  echo "  JWT secrets, etc.) and must NEVER be committed to version control."
  echo ""
  echo "  To unstage the file:"
  echo "    git reset .env"
  echo ""
  echo "  If you intended to commit changes to env variables, use"
  echo "  .env.example instead with placeholder values:"
  echo "    cp .env .env.example"
  echo "    git add .env.example"
  echo ""
  echo "  To bypass this hook (not recommended):"
  echo "    git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
