  "fiscalYearStartMonth": 0,
  "graphTooltip": 3,
  "id": null,
  "links": [
    {
      "title": "Prometheus Metrics",
      "type": "link",
      "url": "/d/ahmedetap-metrics",
      "icon": "external link"
    }
  ],
  "liveNow": false,
