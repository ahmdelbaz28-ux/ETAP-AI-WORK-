    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 202,
      "title": "⏱️ Latency Analysis (Metrics ↔ Traces)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Execution Duration — Prometheus Histogram (P50/P95/P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(execution_duration_seconds_bucket[5m])) by (le, skill_name))",
          "legendFormat": "p50 {{skill_name}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(execution_duration_seconds_bucket[5m])) by (le, skill_name))",
          "legendFormat": "p95 {{skill_name}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(execution_duration_seconds_bucket[5m])) by (le, skill_name))",
          "legendFormat": "p99 {{skill_name}}",
          "refId": "C"
        }
      ]
    },
