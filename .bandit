# .bandit — Bandit YAML configuration for AhmedETAP
# https://bandit.readthedocs.io/en/latest/config.html
#
# Bandit 1.9.x reads this file as YAML when invoked with '-c .bandit'.
# The top-level YAML keys are recognized directly.

# Directories to exclude from scanning
exclude_dirs:
  - tests
  - acp_runtime/tests
  - node_modules
  - .venv
  - venv
  - ui/dist
  - ui/node_modules
  - scripts
  - docs
  - .git
  - __pycache__
  - .pytest_cache
  - .ruff_cache

# Skipped tests (false positives safe in our context):
# B104 = binding to 0.0.0.0 — required for server apps to accept connections
# B108 = /tmp paths — safe on HF Space (ephemeral filesystem)
# B311 = random module — used for non-cryptographic purposes (jitter, load balancing)
# B110 = pass into try block — false positive in our codebase
skips:
  - B104
  - B108
  - B311
  - B110

# Always exit 0 — we rely on # nosec comments + skips list for false-positive
# suppression. Real security issues are caught by Trivy + Safety + custom
# security_scan.py.
exit_zero: true
