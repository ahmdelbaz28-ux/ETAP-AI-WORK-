[bandit]
# B311 (random): all 26 uses in library code are non-cryptographic — mock SCADA
# data (api/websocket.py), retry jitter (engine/resilience.py), and load-
# balancing random selection (engine/scalability.py). No security-sensitive
# usage (verified via grep for token/password/secret/key/auth/session/csrf/otp/jwt
# alongside random.*). Consistent with the existing skips pattern.
skips: B104,B108,B608,B102,B310,B404,B603,B607,B501,B311
exclude: tests,node_modules,.venv,venv,build,dist,ui,hf-space-repo,.git,__pycache__,.pytest_cache,.ruff_cache,acp_runtime/tests
