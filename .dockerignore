.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Reports (generated)
reports/

# Knowledge DB (generated)
knowledge_db/

# Data files
data/
*.db

# Environment files (use .env.example instead)
.env

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in container)
docs/
*.md
!README.md

# Tests
tests/
testsprite_tests/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Node modules (will be installed in container)
node_modules/
ui/

# Temporary files
tmp/
temp/
*.tmp

# Worktrees
worktree-*/

# Blackbox and other AI tools
.blackbox/
.better-agents/
.cursor/
.kilo/
.mastra/

# Prometheus data (generated at runtime)
prometheus_data/

# SSL certificates (sensitive)
ssl/

# Backups
backups/

# CI
.github/
.githooks/
.gitsprite/

# Jupyter notebooks (evaluation files)
*.ipynb

# Scenario tests
tests/scenarios/

# Misc
*.log
*.pid
*.seed
*.pid.lock

# Terraform & Helm (not needed in container)
terraform/
helm/
charts/

# Benchmarks
benchmarks/

# Root-level scripts (not needed in container)
fix_*.py
test_*.py
create_*.py
apply_*.py
modify_*.py
add_*.py
final_*.py
validate_*.py
verify_*.py
run_*.py
start_*.py
locustfile.py
k6-load-test.js

