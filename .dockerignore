# Docker ignore file for ETAP AI Platform

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Reports (generated)
reports/

# Knowledge DB (generated)
knowledge_db/

# Data files
data/
*.db

# Environment files (use .env.example instead)
.env

# Git
.git/
.gitignore

# Documentation (not needed in container)
docs/
*.md
!README.md

# Tests
tests/
.pytest_cache/
htmlcov/
.coverage

# Node modules (will be installed in container)
node_modules/

# Temporary files
tmp/
temp/
*.tmp

# Worktrees
worktree-*/

# Blackbox and other AI tools
.blackbox/
.better-agents/
.cursor/
.kilo/
.mastra/

# Prometheus data (generated at runtime)
prometheus_data/

# SSL certificates (sensitive)
ssl/

# Backups
backups/

# Scripts (not needed in production image, but keep for context if needed)
# scripts/

# CI
.github/

# Jupyter notebooks (evaluation files)
tests/evaluations/
*.ipynb

# Scenario tests
tests/scenarios/

# Misc
*.log
*.pid
*.seed
*.pid.lock
