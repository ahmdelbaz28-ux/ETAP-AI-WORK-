# =============================================================================
# ETAP AI Engineering Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# REQUIRED: Security & Authentication
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: This MUST be set in production. A random key is generated if unset,
# which means JWT tokens will NOT survive process restarts.
JWT_SECRET_KEY=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from JWT_SECRET_KEY automatically.
FERNET_ENCRYPTION_KEY=
ENCRYPTION_KEY=

# =============================================================================
# REQUIRED: LLM API Keys
# =============================================================================
# LOCAL DEV: Set these in .env for local development
# PRODUCTION: Use wrangler secrets (encrypted at rest) for the deployed Worker
#   ./scripts/set-llm-secrets.sh   (Bash)
#   .\scripts\set-llm-secrets.ps1 (PowerShell)
#   ./scripts/verify-secrets.sh    (check what's set)
#
# Primary LLM provider — GPT-4 / GPT-4o
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Fallback LLM provider — Alibaba Qwen (Qwen-Max / Qwen-Turbo)
# Get key: https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# Fallback LLM provider — Zhipu GLM-4
# Get key: https://open.bigmodel.cn/
GLM_API_KEY=

# Fourth LLM provider — NVIDIA NIM (Llama, Mistral, Nemotron, etc.)
# Get key: https://build.nvidia.com/
# Base URL: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# Observability & prompt management
# Get key: https://app.langwatch.ai/
LANGWATCH_API_KEY=sk-lw-dez3fc4HEBQHzS0EvsIfNRWFa2M8SYCJtrKBnERap9HdloTZ

# =============================================================================
# REQUIRED: Database Configuration
# =============================================================================
# LibSQL (Mastra storage)
MASTRA_DB_URL=file:./mastra.db

# PostgreSQL (optional, for production)
DATABASE_URL=
# DATABASE_URL=postgresql://user:password@localhost:5432/etap_platform

# Redis (optional, for caching and distributed queues)
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# REQUIRED: Mastra Configuration
# =============================================================================
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_LOG_LEVEL=info

# =============================================================================
# REQUIRED: Engineering Service (Python computation engine)
# =============================================================================
# URL of the Python Engineering Service (FastAPI)
# Local: http://localhost:8000
# Production: https://engineering-service.yourdomain.com
ENGINEERING_SERVICE_URL=
ENGINEERING_SERVICE_API_KEY=

# Environment: development, staging, or production
# In production, missing ENGINEERING_SERVICE_API_KEY will cause the service to exit
ENVIRONMENT=development

# Set to 'true' to explicitly disable authentication (NOT recommended for production)
# ENGINEERING_SERVICE_AUTH_DISABLED=false

# Comma-separated list of trusted proxy IPs for X-Forwarded-For header validation
# ENGINEERING_SERVICE_TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# =============================================================================
# OPTIONAL: ETAP Integration
# =============================================================================
# ETAP license path (Windows only)
ETAP_LICENSE_PATH=

# ETAP Worker URL (required on Linux/macOS for remote ETAP access)
# ETAP_WORKER_URL=http://etap-worker:8081

# =============================================================================
# OPTIONAL: ETAP & Zenon Manual Knowledge Base
# =============================================================================
# Path to the directory containing ETAP PDF manuals
# Used by knowledge_base/ingest_manuals.py to extract and chunk manuals
# Default: C:\Users\Repair SC\Desktop\New folder\etap
ETAP_MANUALS_PATH=C:\Users\Repair SC\Desktop\New folder\etap

# Path to the directory containing Zenon (COPA-DATA) SCADA manuals
# Used by knowledge_base/ingest_manuals.py to extract and chunk manuals
# Default: C:\Users\Repair SC\Desktop\New folder\zenon
ZENON_MANUALS_PATH=C:\Users\Repair SC\Desktop\New folder\zenon

# Vector database backend: chromadb | faiss | memory
# Default: memory (no external dependencies for development)
RAG_VECTOR_DB=memory

# Embedding model: sentence-transformers | openai
# Default: sentence-transformers (local, no API key required)
RAG_EMBEDDING_MODEL=sentence-transformers

# Chunk size and overlap for manual text extraction
# RAG_CHUNK_SIZE=1500
# RAG_CHUNK_OVERLAP=200

# =============================================================================
# OPTIONAL: Smithery Integration
# =============================================================================
# Smithery API key for MCP server hosting
# Get key: https://smithery.ai/console/api-keys
SMITHERY_API_KEY=771f535b-3dd9-4206-9fba-a8588deedf4a

# =============================================================================
# OPTIONAL: HashiCorp Vault (for secrets management)
# =============================================================================
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=
# VAULT_MOUNT_PATH=secret/etap-platform

# =============================================================================
# OPTIONAL: Email Alerts (for AlertManager)
# =============================================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# ALERT_EMAIL_TO=

# =============================================================================
# OPTIONAL: Webhook Alerts
# =============================================================================
# ALERT_WEBHOOK_URL=

# =============================================================================
# OPTIONAL: Monitoring
# =============================================================================
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# =============================================================================
# OPTIONAL: Performance Tuning
# =============================================================================
# MAX_WORKERS=4
# CACHE_SIZE_MB=512
# CACHE_DEFAULT_TTL=3600
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60

# =============================================================================
# OPTIONAL: Test & CI Configuration
# =============================================================================
# Set to 'true' to skip live LLM scenario tests (e.g., when API keys are invalid or missing)
# SKIP_LIVE_SCENARIO_TESTS=true

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================
# ENABLE_ASYNC_EXECUTION=true
# ENABLE_CACHING=true
# ENABLE_OBSERVABILITY=true
# ENABLE_SECURITY_AUDIT=true
