# Countries to block (comma-separated ISO codes, empty = no blocking)
CF_BLOCKED_COUNTRIES=

# Origin-side rate limit (requests per minute per IP)
CF_ORIGIN_RATE_LIMIT=300

# Comma-separated Akamai secret (alternative edge provider)
AKAMAI_ORIGIN_SECRET=

