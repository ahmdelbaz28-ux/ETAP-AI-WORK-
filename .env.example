# =============================================================================
# 📧 RESEND — Transactional Email Service (Added 2026-07-10)
# =============================================================================
# Dashboard: https://resend.com/api-keys
# Docs: https://resend.com/docs/api-reference/emails/send-email
#
# Free tier: 3,000 emails/month, 100 emails/day
# Restricted API keys: can be scoped to "sending only" (recommended)
#
# Without a verified domain, Resend provides a shared testing sender
# (onboarding@resend.dev) — works but is rate-limited per recipient.
# To use a custom domain: Resend dashboard → Domains → Add domain →
# add DNS records → wait for verification (usually <5 min).
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=AhmedETAP
RESEND_REPLY_TO=
RESEND_TIMEOUT_SECONDS=15
RESEND_MAX_RETRIES=3
RESEND_ENABLED=true

# Rate limiting per recipient (in-memory, per-instance)
RESEND_RATE_LIMIT_MAX=10
RESEND_RATE_LIMIT_WINDOW=60

# Feature flags — toggle individual email flows
RESEND_LOGIN_ALERTS_ENABLED=false       # set true to email on every login
RESEND_LOCKOUT_ALERTS_ENABLED=true      # email when account is auto-locked
RESEND_WELCOME_EMAIL_ENABLED=true       # welcome email after signup
RESEND_NOTIFICATION_EMAILS_ENABLED=true # honor requires_email flag

# Brand identity (used in email templates — AhmedETAP visual identity)
EMAIL_BRAND_NAME=AhmedETAP
EMAIL_BRAND_TAGLINE=Enterprise AI-Powered Power Systems Engineering
EMAIL_SUPPORT_ADDRESS=support@etap-ai-work.vercel.app
EMAIL_APP_URL=https://etap-ai-work.vercel.app
EMAIL_BRAND_PRIMARY=#facc15             # AhmedETAP yellow (gold)
EMAIL_BRAND_SECONDARY=#ef4444           # AhmedETAP red
EMAIL_BRAND_ACCENT=#1e40af              # Deep blue (engineering trust)
EMAIL_BRAND_LOGO_EMOJI=⚡                # AhmedETAP logo (lightning bolt)

# OTP configuration
OTP_TTL_SECONDS=600                     # 10 minutes
OTP_MAX_ATTEMPTS=5
OTP_ISSUE_COOLDOWN_SEC=60               # min seconds between code sends
OTP_ISSUE_COOLDOWN_AFTER_FAILS=3        # cooldown after 3 failed verifies

# Magic Links (passwordless login)
MAGIC_LINK_TTL_SECONDS=900              # 15 minutes
MAGIC_LINK_MAX_USES=1                   # one-shot consumption

# Email Digests (daily/weekly summary)
EMAIL_DIGEST_ENABLED=true
EMAIL_DIGEST_SCHEDULE_DAILY=08:00       # UTC, daily digest send time
EMAIL_DIGEST_SCHEDULE_WEEKLY=MONDAY_08:00  # weekly digest send time
EMAIL_DIGEST_TIMEZONE=UTC

# Email Webhooks (notify external systems on email events)
EMAIL_WEBHOOK_SECRET=your-webhook-hmac-secret  # HMAC-SHA256 shared secret
EMAIL_WEBHOOK_ENDPOINTS=                 # comma-separated URLs (optional)
EMAIL_WEBHOOK_EVENTS=email.sent,email.delivered,email.bounced,email.complained,email.opened,email.clicked

# Email Dashboard (admin monitoring UI)
EMAIL_DASHBOARD_ENABLED=true
EMAIL_DASHBOARD_ADMIN_ROLES=admin,super_admin
EMAIL_DASHBOARD_RETENTION_DAYS=90        # how long to keep email send logs

