# FireAI Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === AI Provider Keys ===
OPENAI_API_KEY=
GEMINI_API_KEY=

# === AI Memory Configuration ===
FIREAI_MEMORY_LLM_PROVIDER=openai
FIREAI_MEMORY_LLM_MODEL=gpt-4o-mini
FIREAI_MEMORY_EMBEDDER_PROVIDER=openai
FIREAI_MEMORY_EMBEDDER_MODEL=text-embedding-3-small

# === Wiki Configuration ===
FIREAI_WIKI_ROOT=

# === FireAI API ===
FIREAI_API_KEY=change-me-in-production
AUDIT_HMAC_KEY=dev-key-change-in-production
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=sqlite:///data/fireai.db
