# =============================================================================
# 🟢 NODE.JS SANDBOX — AI agent JavaScript execution
# =============================================================================
# Used by:
#   - security/secure_node_executor.js (the sandbox runner)
#   - src/mastra/tools/node-tool.ts (Mastra tool wrapper)
#
# The sandbox uses isolated-vm (separate V8 isolate) for hard isolation.
# These limits are enforced at the V8 isolate level, not by the host process.
#
# Docs: docs/NODE_SANDBOX.md

# Hard timeout for sandbox code execution (milliseconds).
# Infinite loops are terminated by V8 itself.
NODE_TIMEOUT_MS=5000

# Memory limit for the V8 isolate (megabytes).
# Memory bombs are caught by V8's heap allocator.
NODE_MEMORY_LIMIT_MB=64

# Maximum code length accepted by the sandbox (characters).
# Prevents resource exhaustion from oversized scripts.
NODE_MAX_CODE_LENGTH=50000

# Maximum output length captured from console.log (characters).
# Outputs longer than this are truncated with a marker.
NODE_MAX_OUTPUT_LENGTH=10000
