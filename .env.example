# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-here
# ALERT_EMAIL_TO=alerts@yourdomain.com

# =============================================================================
# 🎛️ PERFORMANCE TUNING (optional)
# =============================================================================
MAX_WORKERS=4
CACHE_SIZE_MB=512
CACHE_DEFAULT_TTL=3600
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# 🧪 TESTING (optional)
# =============================================================================
SKIP_LIVE_SCENARIO_TESTS=false

# =============================================================================
# ▲ VERCEL — النشر على فيرسل
# =============================================================================
VERCEL_ORG_ID=team_YOUR_VERCEL_ORG_ID_HERE
VERCEL_PROJECT_ID=prj_YOUR_VERCEL_PROJECT_ID_HERE
VERCEL_TOKEN=vcp_YOUR_VERCEL_TOKEN_HERE


# =============================================================================
# 🧠 AI MEMORY & GRAPH DATABASE — الذاكرة الدلالية وتوبولوجيا الشبكة
# =============================================================================
# Qdrant Vector DB (RAG)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Neo4j Graph DB (Network Topology)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-strong-neo4j-password-here

# Qdrant API key (REQUIRED for docker-compose)
# QDRANT_API_KEY=your-strong-qdrant-api-key-here

# =============================================================================
# ⚙️ ADVANCED CONFIGURATION (optional — defaults are sensible)
# =============================================================================
# These env vars are used by the code but were previously undocumented.
# They are optional and have sensible defaults. Documented here for completeness.
# =============================================================================

# ─── JWT Token Expiry ───────────────────────────────────────────────────────
# Access tokens are short-lived (security). Refresh tokens are long-lived.
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Login Rate Limiting ───────────────────────────────────────────────────
# Per-username rate limit to prevent brute-force login attacks.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SEC=300

# ─── Database Connection Pool ───────────────────────────────────────────────
# Tuning for SQLAlchemy async connection pool.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ─── Celery Worker Tuning ───────────────────────────────────────────────────
CELERY_MIN_WORKERS=2
CELERY_MAX_WORKERS=8
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Engineering Service Tuning ─────────────────────────────────────────────
# Disable auth for local development (NEVER set to true in production).
ENGINEERING_SERVICE_AUTH_DISABLED=false
# Disable cache for debugging.
ENGINEERING_SERVICE_CACHE_DISABLED=false
# Override the service host/port (default: 0.0.0.0:8000).
ENGINEERING_SERVICE_HOST=0.0.0.0
ENGINEERING_SERVICE_MAX_BODY_SIZE=10485760
ENGINEERING_SERVICE_REQUEST_TIMEOUT=300
# Rate limiting (per-client).
ENGINEERING_SERVICE_RATE_LIMIT_MAX=100
ENGINEERING_SERVICE_RATE_LIMIT_WINDOW=60
ENGINEERING_SERVICE_RATE_LIMIT_MAX_ENTRIES=10000
# Trusted proxy IPs for X-Forwarded-For header parsing.
ENGINEERING_SERVICE_TRUSTED_PROXIES=
# Service version (auto-set from VERSION file, override for testing).
ENGINEERING_SERVICE_VERSION=

# ─── Embedding Model (for RAG) ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=your-openai-api-key-here

# ─── LLM Model Override ────────────────────────────────────────────────────
# Override the default LLM model for agents that don't specify one.
LLM_MODEL=gpt-4o-mini

# ─── OpenAI Base URL Override ──────────────────────────────────────────────
# For Azure OpenAI or OpenAI-compatible providers.
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Langfuse Toggle ───────────────────────────────────────────────────────
# Disable Langfuse tracing without removing keys (useful for local dev).
LANGFUSE_ENABLED=true
LANGFUSE_PROJECT_ID=

# ─── LangWatch Tuning ──────────────────────────────────────────────────────
LANGWATCH_PROJECT_ID=AhmedETAP
LANGWATCH_DEFAULT_MODEL=gpt-4o
LANGWATCH_OVERRIDE_MODE=false
LANGWATCH_TIMEOUT=5.0

# ─── ETAP Worker (Windows ETAP COM bridge) ─────────────────────────────────
ETAP_WORKER_URL=http://localhost:8081
ETAP_WORKER_API_KEY=your-etap-worker-api-key-here
ETAP_WORKER_PORT=8081
ETAP_PROVIDER=auto
ETAP_PROMPTS_DIR=./prompts

# ─── Cache TTL ─────────────────────────────────────────────────────────────
CACHE_TTL=3600

# ─── API Key Encryption ────────────────────────────────────────────────────
# Fernet key for encrypting stored API keys (separate from ENCRYPTION_KEY).
API_KEY_ENCRYPTION_KEY=your-fernet-key-here

# ─── Code Context Index (for AI agents) ────────────────────────────────────
CODE_CONTEXT_INDEX_DIR=./data/code_index

# ─── ACP Runtime (Agent Communication Protocol) ───────────────────────────
ACP_AUTH_SECRET=your-acp-auth-secret-here
ACP_HANDLERS=
ACP_SCOPES=
ACP_DEFAULT_LABELS=
ACP_WS_HOST=0.0.0.0
ACP_UDS_PATH=/tmp/acp.sock
ACP_AUDIT_LOG=/tmp/acp_audit.jsonl
ACP_TRACE_FILE=/tmp/acp_trace.jsonl

# ─── DuckDB Store (alternative state store) ────────────────────────────────
DUCKDBSTORE_DB_PATH=./data/duckdb_state.db
DUCKDBSTORE_IMPORT_PATH=
DUCKDBSTORE_CONSTRUCTOR_KWARGS_JSON={}

# ─── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# ─── Language Auto-Correction ──────────────────────────────────────────────
AUTO_CORRECT_LANGUAGE=true

# ─── Display (for GUI automation on Linux) ─────────────────────────────────
DISPLAY=:0

# ─── HF Space Production Tests ─────────────────────────────────────────────
# Set to 'true' when running tests/test_hf_space_production.py against
# the live HF Space deployment.
HF_SPACE_PRODUCTION_TESTS=false

# =============================================================================
# 🚨 ERROR TRACKING (Sentry — optional)
# =============================================================================
# When configured, unhandled exceptions are sent to Sentry with full stack
# traces, breadcrumbs, and sanitized context. When not configured, errors
# fall back to structured logging via structlog.
#
# Get a DSN at: https://sentry.io/settings/<org>/projects/<project>/keys/
# Self-hosted Sentry: https://develop.sentry.dev/self-hosted/
#
# Security: core/error_tracking.py automatically scrubs:
#   - API keys (sk-*, ghp_*, hf_*, sb_secret_*, sb_publishable_*)
#   - JWT tokens (eyJ... pattern)
#   - Bearer tokens
#   - Any value with key matching: password, api_key, secret, token, jwt,
#     authorization, cookie, session_id, private_key, fernet_key, etc.
#   - User IP addresses (never sent)
#   - Request bodies > 8KB (truncated)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0