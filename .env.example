# ☁️ CLOUDFLARE EDGE PROTECTION — حماية Cloudflare
# =============================================================================
# Shared secret between CF Worker and origin (blocks direct origin access)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
