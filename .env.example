```
# Environment Variables Template
# Copy this file to .env and fill in actual values for your environment
# NEVER commit .env files to version control - it's in .gitignore

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Deployment environment: "development" or "production"
FIREAI_ENV=development

# =============================================================================
# APPLICATION SECURITY
# =============================================================================

# Master API key for FireAI authentication (REQUIRED IN PRODUCTION)
# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be set to a secure random value in production
FIREAI_API_KEY=your-random-token-here-generate-using-python-c-import-secrets-print-secrets-token-urlsafe-32

# Environment environment: "development" or "production"
FIREAI_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL (PostgreSQL recommended)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://revit_user:change_me_password@localhost:5432/revit_db

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Deployment environment: "development" or "production"
FIREAI_ENV=development

# =============================================================================
# DOCUMENTATION
# =============================================================================

# API documentation generation tool (Swagger/OpenAPI)
SWAGGER_ENABLED=true
OPENAPI_ENABLED=true
