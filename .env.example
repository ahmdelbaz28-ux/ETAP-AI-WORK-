# =============================================================================
# AhmedETAP — Complete Environment Configuration
# =============================================================================
# نسخ هذا الملف إلى .env وأدخل قيمك الحقيقية
# Copy this file to .env and fill in your real values
# ⚠️ NEVER commit .env to version control
# =============================================================================

# =============================================================================
# 🔐 SECURITY & AUTHENTICATION — الأمان والمصادقة
# =============================================================================
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=your-fernet-key-here
ENCRYPTION_KEY=your-encryption-key-here

ENVIRONMENT=development    # development | staging | production
PORT=8000
HOST=0.0.0.0

# =============================================================================
# 🗄️ DATABASE — قاعدة البيانات
# =============================================================================
# Local SQLite (recommended for dev)
DATABASE_URL=sqlite+aiosqlite:///./etap.db

# Production PostgreSQL (uncomment for prod)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/etap_db

# PostgreSQL credentials (REQUIRED for docker-compose)
POSTGRES_DB=etap_db
POSTGRES_USER=your-postgres-username-here
POSTGRES_PASSWORD=your-strong-postgres-password-here

# =============================================================================
# ⚡ REDIS CACHE — التخزين المؤقت
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# For docker-compose: Redis password (REQUIRED)
# REDIS_PASSWORD=your-strong-redis-password-here

# =============================================================================
# 🤗 HUGGING FACE — هاجينج فيس
# =============================================================================
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN_HERE
HF_SPACE_NAME=ahmdelbaz28/AHMEDETAP
HF_REPO_URL=https://huggingface.co/spaces/ahmdelbaz28/AHMEDETAP

# =============================================================================
# 📊 LANGWATCH — مراقبة الـ LLM (Free plan = 3 prompts limit)
# =============================================================================
# Dashboard: https://app.langwatch.ai/
# Docs: https://docs.langwatch.ai/
# NOTE: Free plan is limited to 3 prompts per project. For unlimited prompts,
#       use Langfuse instead (see LANGFUSE section below).
LANGWATCH_API_KEY=sk-lw-YOUR_LANGWATCH_KEY_HERE
LANGWATCH_PROJECT=AhmedETAP
LANGWATCH_ENDPOINT=https://app.langwatch.ai

# =============================================================================
# 📊 LANGFUSE — إدارة البرومبتات والمراقبة (Unlimited on free plan)
# =============================================================================
# Dashboard: https://cloud.langfuse.com/
# Docs: https://langfuse.com/docs
# Free Hobby plan supports UNLIMITED prompts, 50k observations/month.
#
# Sync prompts to Langfuse:
#   python scripts/sync_to_langfuse.py
# Manage prompt versions/labels:
#   python scripts/langfuse_prompt_manager.py list
#   python scripts/langfuse_prompt_manager.py promote arcflash_agent staging
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_LANGFUSE_PUBLIC_KEY_HERE
LANGFUSE_SECRET_KEY=sk-lf-YOUR_LANGFUSE_SECRET_KEY_HERE
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_DEFAULT_MODEL=gpt-4o

# ─── Safety-critical LLM guardrails ─────────────────────────────────────
# These guardrails protect against prompt-injection and unapproved-model
# attacks on safety-critical engineering agents.
LLM_MAX_INPUT_CHARS=50000            # refuse inputs longer than this
LLM_ALLOW_UNKNOWN_MODELS=false       # refuse models not in the allowlist
LLM_REQUIRE_AGENT_TAG=true           # refuse calls without an agent metadata tag
LLM_APPROVED_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo,gpt-4.1,gpt-4.1-mini,claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022,claude-3-opus-20240229,gemini-2.0-flash-exp,gemini-1.5-pro

# ─── Langfuse safety alerts ────────────────────────────────────────────
# Optional webhook (Slack/Teams/email) for safety alerts.
# Leave empty to disable webhook delivery (alerts still logged + scored).
LANGFUSE_ALERT_WEBHOOK_URL=
LANGFUSE_ALERT_WEBHOOK_HEADERS={}

# ─── Langfuse HTTP middleware ──────────────────────────────────────────
# Routes that are considered safety-critical (5xx here triggers an alert).
LANGFUSE_SAFETY_PATHS=/api/studies/run,/api/studies/,/api/agents/,/api/scada/,/api/digital-twin/,/api/validation/,/api/context-engine/,
LANGFUSE_HTTP_MAX_BODY=4096

# ─── Langfuse prompt loading (safety-critical) ─────────────────────────
# When OVERRIDE_MODE=true, remote Langfuse prompts can override local YAML
# (after integrity hash check). Default: false (YAML always wins).
LANGFUSE_OVERRIDE_MODE=false
LANGFUSE_TIMEOUT=5.0
LANGFUSE_MAX_CAPTURE_CHARS=4096

# =============================================================================
# 🗄️ SUPABASE — Managed PostgreSQL + Storage + optional Auth
# =============================================================================
# Dashboard: https://supabase.com/dashboard
# Docs: https://supabase.com/docs
# Free tier: 500MB Postgres + 1GB Storage + 50k monthly active users
#
# ⚠️ CRITICAL FOR HF SPACE: HF Space wipes the filesystem on every restart.
# SQLite data is LOST on restart. Supabase Postgres solves this.
#
# To enable:
# 1. Create a project at https://supabase.com
# 2. Get these values from: Dashboard → Project Settings → API
# 3. For DATABASE_URL: Dashboard → Project Settings → Database → Connection string
#    Use the "Session mode" pooler (port 5432) for SQLAlchemy/asyncpg.
#    The "Transaction mode" pooler (port 6543) does NOT support prepared
#    statements, which SQLAlchemy needs.
#
# Format:
#   postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-N-REGION.pooler.supabase.com:5432/postgres
#
# Note the "aws-N-" prefix (N can be 0 or 1 — check your project's pooler
# config in the Supabase dashboard).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_KEY_HERE

# ⚠️ SECURITY: SERVICE_ROLE_KEY bypasses Row-Level Security. NEVER commit
# the real value to git. NEVER expose it to the frontend. Only set it
# as an environment variable in the server / HF Space secrets.

# Database connection string (Supabase Postgres, session-mode pooler)
# Use port 5432 (session mode) — port 6543 (transaction mode) breaks
# SQLAlchemy's prepared-statement cache.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Optional: enable Supabase Auth (social login: Google, GitHub, etc.)
SUPABASE_AUTH_ENABLED=false

# Optional: Supabase Personal Access Token (PAT) for Management API.
# Used by admin scripts to fetch project info, reset passwords, etc.
# NOT required for runtime — only for ops/admin tooling.
# Create at: https://supabase.com/dashboard/account/tokens
SUPABASE_PAT=

# =============================================================================
# 🔧 SMITHERY MCP — بروتوكول السياق النموذجي
# =============================================================================
# Dashboard: https://smithery.ai/console/api-keys
# Docs: https://smithery.ai/docs
SMITHERY_API_KEY=YOUR_SMITHERY_API_KEY_HERE
SMITHERY_BASE_URL=https://api.smithery.ai

# =============================================================================
# 🧠 LLM API KEYS — مفاتيح نماذج الذكاء الاصطناعي
# =============================================================================
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic Vision config (for multi-vendor vision chain)
ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=30
ANTHROPIC_MAX_RETRIES=3

# Google Gemini — https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI-compatible Vision API — works with OpenAI, Azure, Together AI, Groq, etc.
# For OpenAI: OPENAI_BASE_URL=https://api.openai.com/v1 (default)
# For Azure:  OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=3

# Gemini Vision API key for the ETAP GUI Agent (Computer Use Agent).
# This is the SAME Google API key but used specifically by
# integrations/gemini_vision.py to analyze screenshots and decide
# the next CUA action (click coordinates, text to type, hotkeys).
# Without this key, the CUA Loop cannot run (the agent falls back to
# Format U "planning-only" response).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the default Gemini model (default: gemini-2.0-flash-exp)
# Other options: gemini-1.5-pro, gemini-1.5-flash, gemini-pro-vision
GEMINI_MODEL=gemini-2.0-flash-exp

# Optional: per-request timeout in seconds (default: 30)
GEMINI_TIMEOUT=30

# Optional: max retries on transient API errors (default: 3)
GEMINI_MAX_RETRIES=3

# =============================================================================
# 📡 SIEM SYSLOG — إرسال أحداث الأمان إلى SIEM (Syslog RFC 5424)
# =============================================================================
# Forwards life-safety audit events (lethal blocks, kill switch activations,
# dual confirmation requests) to your enterprise SIEM via standard Syslog.
# Compatible with: Splunk, IBM QRadar, Google Chronicle, ArcSight.
#
# To enable: set SIEM_ENABLED=true and SIEM_HOST to your SIEM server IP/hostname
SIEM_ENABLED=false
SIEM_HOST=
SIEM_PORT=514
SIEM_PROTOCOL=udp
SIEM_FACILITY=local0
SIEM_SEVERITY=warning
SIEM_APP_NAME=AhmedETAP-CUA
SIEM_TLS_CA_CERT=
# LOGGING-ONLY MODE: when SIEM_LOG_FILE is set (and SIEM_HOST is empty),
# events are written to a local JSONL file instead of being sent over network.
# Useful for testing without a SIEM server, or on HF Space (no inbound network).
# Example: SIEM_LOG_FILE=/tmp/siem_events.jsonl
SIEM_LOG_FILE=

# NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# =============================================================================
# 🤖 CLOVIE ROUTER — OpenAI-compatible gateway for MiMo models
# =============================================================================
# Free MiMo API gateway supporting Hermes, OpenClaw, Cline, Claude Code.
# Top up credits at: https://gitlawb.com/opengateway/credits
#
# Available models:
#   mimo-v2.5-pro    — Latest flagship (strongest reasoning)
#   mimo-v2.5        — Latest balanced
#   mimo-v2-omni     — Multimodal (vision + text)
#   mimo-v2-pro      — Previous-gen pro
#   mimo-v2-flash    — Fastest, cheapest (DEFAULT)
CLOVIE_API_KEY=clovie-YOUR_CLOVIE_API_KEY_HERE
CLOVIE_BASE_URL=https://clovievalen-clovie-router.hf.space/v1
CLOVIE_MODEL=mimo-v2-flash

# =============================================================================
# 🔌 ENGINEERING SERVICE — خدمة الهندسة
# =============================================================================
ENGINEERING_SERVICE_URL=http://localhost:8000
ENGINEERING_SERVICE_PORT=8000
ENGINEERING_SERVICE_API_KEY=your-service-api-key-here

# ETAP Integration (optional)
USE_ETAP=false
ETAP_LICENSE_PATH=
ETAP_HOST=localhost
ETAP_PORT=5000

# =============================================================================
# 🐙 GITHUB — جيت هاب
# =============================================================================
# GitHub PAT — https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_GITHUB_PAT_HERE
GITHUB_REPO=ahmdelbaz28-ux/ETAP-AI-WORK-

# =============================================================================
# 📡 OBSERVABILITY — المراقبة
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=your-grafana-password-here
# Note: docker-compose.yml uses GRAFANA_ADMIN_PASSWORD (same value as above)
GRAFANA_ADMIN_PASSWORD=your-strong-grafana-admin-password-here

# CORS Origins (comma-separated, no spaces)
ENGINEERING_SERVICE_CORS_ORIGINS=http://localhost:3000

# =============================================================================
# 🔒 SECRETS MANAGER (HashiCorp Vault — optional)
# =============================================================================
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token-here
# VAULT_MOUNT_PATH=secret/etap-platform

# =============================================================================
# 📧 EMAIL ALERTS (optional)
# =============================================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-here
# ALERT_EMAIL_TO=alerts@yourdomain.com

# =============================================================================
# 🎛️ PERFORMANCE TUNING (optional)
# =============================================================================
MAX_WORKERS=4
CACHE_SIZE_MB=512
CACHE_DEFAULT_TTL=3600
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# 🧪 TESTING (optional)
# =============================================================================
SKIP_LIVE_SCENARIO_TESTS=false

# =============================================================================
# ▲ VERCEL — النشر على فيرسل
# =============================================================================
VERCEL_ORG_ID=team_YOUR_VERCEL_ORG_ID_HERE
VERCEL_PROJECT_ID=prj_YOUR_VERCEL_PROJECT_ID_HERE
VERCEL_TOKEN=vcp_YOUR_VERCEL_TOKEN_HERE


# =============================================================================
# 🧠 AI MEMORY & GRAPH DATABASE — الذاكرة الدلالية وتوبولوجيا الشبكة
# =============================================================================
# Qdrant Vector DB (RAG)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Neo4j Graph DB (Network Topology)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-strong-neo4j-password-here

# Qdrant API key (REQUIRED for docker-compose)
# QDRANT_API_KEY=your-strong-qdrant-api-key-here